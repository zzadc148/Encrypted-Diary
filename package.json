{
  "name": "local-encrypted-diary",
  "private": true,
  "version": "2.0.2",
  "description": "Electron + React local encrypted diary app",
  "main": "dist/electron/electron/main.js",
  "type": "commonjs",
  "scripts": {
    "build": "vite build && tsc -p tsconfig.electron.json && electron-builder",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:renderer": "vite",
    "start": "electron dist/electron/electron/main.js"
  },
  "dependencies": {
    "antd": "^5.23.0",
    "@ant-design/icons": "^5.5.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.13.4",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.codex.localencrypteddiary",
    "productName": "Encrypted Diary",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName} Setup ${version}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
